# Copy to .env and fill in. Do not commit .env (.gitignore covers it).
LITELLM_MASTER_KEY=sk-change-me-please

# Used by the ./ai-stack helper and sample-benchmark.py
AI_STACK_HOST=user@dgx-spark.local
AI_STACK_BASE_URL=http://dgx-spark.local:4000/v1

# Host models dir, mounted read-only at /models in the vllm-nvfp4 container.
# Must contain the NVFP4 checkpoint dir: Qwen3.6-35B-A3B-NVFP4/
# (from huggingface.co/nvidia/Qwen3.6-35B-A3B-NVFP4)
LLAMA_MODEL_DIR=/path/to/models

# LEGACY (unused since the move to vLLM NVFP4) — only the archived llama.cpp
# service read these. Safe to leave blank.
LLAMA_MODEL_FILE=
LLAMA_CTX=
LLAMA_NGL=
LLAMA_BUILD_CONTEXT=

WHISPER_MODEL_DIR=/path/to/whisper-models
WHISPER_MODEL_FILE=ggml-large-v3.bin

LITELLM_PORT=4000
