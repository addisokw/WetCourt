# Copy to .env and fill in. Do not commit .env (.gitignore covers it).
LITELLM_MASTER_KEY=sk-change-me-please

# Used by the ./ai-stack helper and sample-benchmark.py
AI_STACK_HOST=user@dgx-spark.local
AI_STACK_BASE_URL=http://dgx-spark.local:4000/v1

# Path on the DGX where the GGUF lives, and the filename inside it.
LLAMA_MODEL_DIR=/path/to/models
LLAMA_MODEL_FILE=Qwen3.6-35B-A3B-UD-Q4_K_M.gguf
LLAMA_CTX=32768
LLAMA_NGL=99

# Path to a freshly-built llama.cpp checkout's build/bin directory; used as
# the docker build context so we package the local llama-server binary.
LLAMA_BUILD_CONTEXT=/path/to/llama.cpp/build/bin

WHISPER_MODEL_DIR=/path/to/whisper-models
WHISPER_MODEL_FILE=ggml-large-v3.bin

LITELLM_PORT=4000
