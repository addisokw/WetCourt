# Copy to .env and fill in. Never commit .env.

# Tailscale auth key — reusable recommended so the node re-auths cleanly across
# restarts. Generate at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# Name this node shows up as in your tailnet (optional).
TS_HOSTNAME=wetcourt-orchestrator

# Host port the UI is published on (loopback only; cloudflared points here).
# Default 26878 = "COURT" on a phone keypad. Change if it clashes.
HOST_PORT=26878

# LiteLLM master key — copy from the Spark. The orchestrator uses it to auth to
# LiteLLM; it lives only on the Spark, so you must bring it here.
LITELLM_MASTER_KEY=sk-xxxxxxxxxxxx

# Your Spark's reachable LiteLLM address — its Tailscale IP or MagicDNS name
# (e.g. http://100.x.y.z:4000 or http://dgx-spark.your-tailnet.ts.net:4000).
# Kept here so your tailnet address stays out of the committed config.
SPARK_BASE_URL=http://your-spark:4000
