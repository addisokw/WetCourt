# Copy to `.env` (gitignored) and fill in. Both the orchestrator and counsel
# load this file at startup (repo root, or dgx-ai-stack/.env) and merge
# BOOTH__* / COUNSEL__* vars over their TOML configs — real hosts and keys
# live here, never in the committed configs.

# LiteLLM key from the ai-stack; auto-aliased into BOOTH__INFERENCE__API_KEY
# and COUNSEL__INFERENCE__API_KEY.
LITELLM_MASTER_KEY=sk-your-litellm-key

# Where the inference stack (LiteLLM on the Spark) is reachable from this
# machine — Tailscale IP / MagicDNS name, or LAN IP.
BOOTH__INFERENCE__BASE_URL=http://your-spark:4000
COUNSEL__INFERENCE__BASE_URL=http://your-spark:4000
